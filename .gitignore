# --- SENSITIVE DATA (WAJIB DIABAIKAN) ---
# Mengabaikan kunci SSH pribadi Anda
.ssh/
ssh/
*.pub
*%USERPROFILE%\.ssh/

# Mengabaikan file variabel lingkungan (rahasia API/DB)
.env
.env.local
.env.*.local

# --- DEPENDENCIES & BUILD ---
# Folder library yang sangat berat
node_modules/
jspm_packages/

# Folder hasil build (jika menggunakan Vite/React)
dist/
build/
.vercel/

# --- DOCKER (KARENA TIDAK DIGUNAKAN DI GITHUB PAGES) ---
# Mengabaikan file Docker karena Anda hanya pakai GitHub Pages
Dockerfile
.dockerignore

# --- LOGS & DEBUG ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- OS FILES ---
.DS_Store
Thumbs.db
desktop.ini